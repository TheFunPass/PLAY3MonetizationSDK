      <string name="Name">PLAY3 SDK</string>
      <ProtectedString name="Source"><![CDATA[--[[
	PLAY3 SDK Plugin

	Installs the PLAY3 monetization SDK into your game.

	Flow:
	1. User enters API key
	2. Plugin validates format
	3. SDK is installed with API key pre-configured
]]

-- Only run as a plugin
if not plugin then
	return
end

-- Prevent double execution (Studio sometimes runs in multiple contexts)
local RunService = game:GetService("RunService")
if RunService:IsClient() then
	return
end

