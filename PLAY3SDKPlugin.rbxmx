-- STATE
--============================================================

local isValidApiKey = false
local enteredApiKey = ""
local currentTab = "setup"

-- Plugin settings for persistence
local SETTINGS_KEY = "PLAY3_API_KEY"

local function saveApiKey(key)
	pcall(function()
		plugin:SetSetting(SETTINGS_KEY, key)
	end)
end

local function loadApiKey()
	local success, key = pcall(function()
		return plugin:GetSetting(SETTINGS_KEY)
	end)
	if success and key and key ~= "" then
		return key
	end
	return nil
end

--============================================================
-- TAB SWITCHING
--============================================================

local function switchTab(tab)
	currentTab = tab

	if tab == "setup" then
		setupTab.BackgroundColor3 = COLORS.neonGreen
		setupTab.TextColor3 = COLORS.voidBlack
		toolsTab.BackgroundColor3 = COLORS.voidBlack
		toolsTab.TextColor3 = COLORS.textMuted
		setupPanel.Visible = true
		toolsPanel.Visible = false
	else
		setupTab.BackgroundColor3 = COLORS.voidBlack
		setupTab.TextColor3 = COLORS.textMuted
		toolsTab.BackgroundColor3 = COLORS.neonGreen
		toolsTab.TextColor3 = COLORS.voidBlack
		setupPanel.Visible = false
		toolsPanel.Visible = true
	end
end

--============================================================
-- VERSION UTILITIES
--============================================================

local function parseVersion(v)
	local maj, min, pat = (v or "0.0.0"):match("(%d+)%.(%d+)%.(%d+)")
	return tonumber(maj) or 0, tonumber(min) or 0, tonumber(pat) or 0
end

local function isNewer(installed, pluginVer)
	local a1, b1, c1 = parseVersion(installed)
	local a2, b2, c2 = parseVersion(pluginVer)
	if a2 > a1 then return true end
	if a2 < a1 then return false end
	if b2 > b1 then return true end
	if b2 < b1 then return false end
	return c2 > c1
end

local function getInstalledVersion()
	local sdk = ServerScriptService:FindFirstChild("PLAY3SDK")
	if not sdk then return nil end

	local ver = sdk:FindFirstChild("_VERSION")
	if ver and ver:IsA("StringValue") then
		return ver.Value
	end

	local init = sdk:FindFirstChild("init")
	if init and init:IsA("ModuleScript") then
		local match = init.Source:match('VERSION%s*=%s*"([%d%.]+)"')
		return match
	end

	return "0.0.0"
end

local function getInstalledApiKey()
	local sdk = ServerScriptService:FindFirstChild("PLAY3SDK")
	if not sdk then return nil end

	local config = sdk:FindFirstChild("Config")
	if config and config:IsA("ModuleScript") then
		local key = config.Source:match('API_KEY%s*=%s*"([^"]*)"')
		return key
	end

	return nil
end

--============================================================
-- REMOTE VERSION CHECK
--============================================================

local function checkForPluginUpdate()
	task.spawn(function()
		local success, result = pcall(function()
			local response = HttpService:GetAsync(VERSION_URL)
			return HttpService:JSONDecode(response)
		end)

		if success and result then
			remoteVersionInfo = result
			local latestVersion = result.version

			if latestVersion and isNewer(PLUGIN_VERSION, latestVersion) then
				local changelog = result.changelog or "New version available"
				updateBannerText.Text = "<b>Plugin v" .. latestVersion .. " available!</b>\n" .. changelog
				updateBanner.Visible = true
				print("[PLAY3.AI] Plugin update available: v" .. latestVersion)
			else
				print("[PLAY3.AI] Plugin is up to date (v" .. PLUGIN_VERSION .. ")")
			end
		else
			print("[PLAY3.AI] Could not check for updates")
		end
	end)
end

--============================================================
-- API KEY VALIDATION
--============================================================

local function validateApiKey(key)
	if not key or key == "" then
		return false, ""
	end

	key = key:match("^%s*(.-)%s*$")

	if key:match(API_KEY_PATTERN) then
		return true, key
	else
		return false, key
	end
end

local function updateValidation()
	local valid, cleanKey = validateApiKey(apiKeyInput.Text)
	isValidApiKey = valid
	enteredApiKey = cleanKey

	-- Show tabs only when API key is valid (onboarding flow)
	tabBar.Visible = valid

	if apiKeyInput.Text == "" then
		validationLabel.Text = ""
		inputStroke.Color = COLORS.whiteBorder
		actionBtn.BackgroundColor3 = COLORS.whiteMuted
		actionBtn.TextColor3 = COLORS.textDim
		actionBtn.Text = "ENTER API KEY FIRST"
		actionBtn.AutoButtonColor = false
	elseif valid then
		validationLabel.Text = "✓ Valid API key format"
		validationLabel.TextColor3 = COLORS.neonGreen
		inputStroke.Color = COLORS.neonGreen
		actionBtn.AutoButtonColor = true

		-- Save API key for future sessions
		saveApiKey(cleanKey)

		local installed = getInstalledVersion()
		if installed then
			if isNewer(installed, PLUGIN_VERSION) then
				actionBtn.BackgroundColor3 = COLORS.playerBlue
				actionBtn.TextColor3 = COLORS.white
				actionBtn.Text = "UPDATE SDK"
			else
				actionBtn.BackgroundColor3 = COLORS.whiteMuted
				actionBtn.TextColor3 = COLORS.white
				actionBtn.Text = "REINSTALL SDK"
			end
		else
			actionBtn.BackgroundColor3 = COLORS.neonGreen
			actionBtn.TextColor3 = COLORS.voidBlack
			actionBtn.Text = "INSTALL SDK"
		end
	else
		validationLabel.Text = "Invalid format. Expected: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
		validationLabel.TextColor3 = COLORS.legacyRed
		inputStroke.Color = COLORS.legacyRed
		actionBtn.BackgroundColor3 = COLORS.whiteMuted
		actionBtn.TextColor3 = COLORS.textDim
		actionBtn.Text = "INVALID API KEY"
		actionBtn.AutoButtonColor = false
	end
end

--============================================================
-- CONFIG PRESERVATION
--============================================================

local function extractConfig(sdk)
	local config = sdk:FindFirstChild("Config")
	if config and config:IsA("ModuleScript") then
		return config.Source
	end
	return nil
end

local function mergeConfig(oldSource, newSource, newApiKey)
	local result = newSource or oldSource

	if newApiKey and newApiKey ~= "" then
		result = result:gsub('API_KEY%s*=%s*"[^"]*"', 'API_KEY = "' .. newApiKey .. '"')
	end

	if not oldSource then
		return result
	end

	local catStart, catEnd = oldSource:find("CATALOG%s*=%s*%b{}")
	if catStart then
		local oldCatalog = oldSource:sub(catStart, catEnd)
		if oldCatalog:find("%w+%s*=%s*") then
			local newCatStart, newCatEnd = result:find("CATALOG%s*=%s*%b{}")
			if newCatStart then
				result = result:sub(1, newCatStart - 1) .. oldCatalog .. result:sub(newCatEnd + 1)
			end
		end
	end

	local gcStart = oldSource:find("\n%s*GAME_CONTEXT%s*=")
	if gcStart and not oldSource:sub(math.max(1, gcStart-5), gcStart):find("%-%-") then
		local gcEnd = gcStart
		local depth = 0
		local started = false
		for i = gcStart, #oldSource do
			local c = oldSource:sub(i, i)
			if c == "{" then depth = depth + 1; started = true end
			if c == "}" then depth = depth - 1 end
			if started and depth == 0 then
				gcEnd = i
				break
			end
		end
		local oldGC = oldSource:sub(gcStart, gcEnd)
		local insertPoint = result:find("testGroupPercent")
		if insertPoint then
			result = result:sub(1, insertPoint - 1) .. oldGC .. ",\n\n\t" .. result:sub(insertPoint)
		end
	end

	local testGroup = oldSource:match("testGroupPercent%s*=%s*(%d+)")
	if testGroup then
		result = result:gsub("testGroupPercent%s*=%s*%d+", "testGroupPercent = " .. testGroup)
	end

	local cacheTTL = oldSource:match("cacheTTL%s*=%s*(%d+)")
	if cacheTTL then
		result = result:gsub("cacheTTL%s*=%s*%d+", "cacheTTL = " .. cacheTTL)
	end

	local debug = oldSource:match("debug%s*=%s*(%w+)")
	if debug then
		result = result:gsub("debug%s*=%s*%w+", "debug = " .. debug)
	end

	return result
end

--============================================================
-- INSTALLATION
--============================================================

local function installSDK()
	if not isValidApiKey then
		status.Text = "Please enter a valid API key first"
		status.TextColor3 = COLORS.legacyRed
		return
	end

	if not EmbeddedSDK then
		status.Text = "Error: SDK not found in plugin!"
		status.TextColor3 = COLORS.legacyRed
		return
	end

	ChangeHistoryService:SetWaypoint("Before PLAY3 SDK Install")

	status.Text = "Installing SDK..."
	status.TextColor3 = COLORS.textSecondary
	actionBtn.BackgroundColor3 = COLORS.whiteMuted
	actionBtn.Text = "INSTALLING..."
	actionBtn.AutoButtonColor = false

	local existingSDK = ServerScriptService:FindFirstChild("PLAY3SDK")
	local existingConfig = existingSDK and extractConfig(existingSDK)

	if existingSDK then
		existingSDK:Destroy()
	end

	local sps = StarterPlayer:FindFirstChild("StarterPlayerScripts")
	if sps then
		local oldClient = sps:FindFirstChild("PLAY3Client")
		if oldClient then
			oldClient:Destroy()
		end
	end

	local oldRemotes = ReplicatedStorage:FindFirstChild("PLAY3Remotes")
	if oldRemotes then
		oldRemotes:Destroy()
	end

	local newSDK = EmbeddedSDK:Clone()

	local versionVal = newSDK:FindFirstChild("_VERSION")
	if not versionVal then
		versionVal = Instance.new("StringValue")
		versionVal.Name = "_VERSION"
		versionVal.Parent = newSDK
	end
	versionVal.Value = PLUGIN_VERSION

	local newConfig = newSDK:FindFirstChild("Config")
	if newConfig then
		newConfig.Source = mergeConfig(existingConfig, newConfig.Source, enteredApiKey)
	end

	newSDK.Parent = ServerScriptService

	if EmbeddedClient then
		if not sps then
			sps = StarterPlayer:WaitForChild("StarterPlayerScripts", 5)
		end
		if sps then
			local newClient = EmbeddedClient:Clone()
			newClient.Parent = sps
		end
	end

	if EmbeddedRemotes then
		local newRemotes = EmbeddedRemotes:Clone()
		newRemotes.Parent = ReplicatedStorage
	end

	-- Enable scripts after installation (they are disabled in plugin to prevent auto-execution)
	for _, desc in newSDK:GetDescendants() do
		if desc:IsA("Script") or desc:IsA("LocalScript") then
			desc.Disabled = false
		end
	end
	if sps then
		local clientFolder = sps:FindFirstChild("PLAY3Client")
		if clientFolder then
			for _, desc in clientFolder:GetDescendants() do
				if desc:IsA("LocalScript") then
					desc.Disabled = false
				end
			end
		end
	end

	ChangeHistoryService:SetWaypoint("After PLAY3 SDK Install")

	status.Text = "SDK installed successfully!"
	status.TextColor3 = COLORS.neonGreen

	if newConfig then
		Selection:Set({newConfig})
	end

	task.delay(2, function()
		refreshStatus()
	end)
end

--============================================================
-- STATUS REFRESH
--============================================================

function refreshStatus()
	local installed = getInstalledVersion()
	local installedKey = getInstalledApiKey()
	local savedKey = loadApiKey()

	-- Pre-fill API key: prefer installed config, then saved setting
	if apiKeyInput.Text == "" then
		if installedKey and installedKey ~= "" then
			apiKeyInput.Text = installedKey
		elseif savedKey and savedKey ~= "" then
			apiKeyInput.Text = savedKey
		end
	end

	if installed then
		versionLabel.Text = "Installed: v" .. installed .. " | Plugin: v" .. PLUGIN_VERSION

		if isNewer(installed, PLUGIN_VERSION) then
			status.Text = "Update available! Config will be preserved."
			status.TextColor3 = COLORS.playerBlue
		else
			status.Text = "SDK is installed and up to date."
			status.TextColor3 = COLORS.neonGreen
		end
	else
		versionLabel.Text = "v" .. PLUGIN_VERSION
		status.Text = "Enter your API key to get started"
		status.TextColor3 = COLORS.textSecondary
	end

	updateValidation()
end

--============================================================
-- EVENTS
--============================================================

installBtn.Click:Connect(function()
	widget.Enabled = not widget.Enabled
	if widget.Enabled then
		refreshStatus()
	end
end)

setupTab.MouseButton1Click:Connect(function()
	switchTab("setup")
end)

toolsTab.MouseButton1Click:Connect(function()
	switchTab("tools")
end)

apiKeyInput:GetPropertyChangedSignal("Text"):Connect(updateValidation)
apiKeyInput.FocusLost:Connect(updateValidation)

actionBtn.MouseButton1Click:Connect(function()
	if isValidApiKey then
		installSDK()
	end
end)

-- List Developer Products
listProductsBtn.MouseButton1Click:Connect(function()
	listProductsTitle.Text = "📦 FETCHING..."

	task.spawn(function()
		local products = {}
		local success, pages = pcall(function()
			return MarketplaceService:GetDeveloperProductsAsync()
		end)

		if not success or not pages then
			warn("[PLAY3.AI] Failed to fetch products. Make sure game is published.")
			listProductsTitle.Text = "📦 LIST DEVELOPER PRODUCTS"
			return
		end

		while true do
			for _, item in ipairs(pages:GetCurrentPage()) do
				table.insert(products, {
					id = item.ProductId,
					name = item.Name,
					price = item.PriceInRobux or 0,
				})
			end
			if pages.IsFinished then break end
			pcall(function() pages:AdvanceToNextPageAsync() end)
		end

		table.sort(products, function(a, b) return a.price < b.price end)

		print("\n========== YOUR DEVELOPER PRODUCTS ==========\n")

		if #products == 0 then
			print("No products found. Create them in Game Settings > Monetization.")
		else
			for _, p in ipairs(products) do
				print(string.format("{ tier = X, price = %d, productId = %d }, -- %s", p.price, p.id, p.name))
			end
		end

		print("\n==============================================")
		print("Copy these lines into your CATALOG table in Config")
		print("Replace 'X' with the tier number (1, 2, 3, etc.)\n")

		listProductsTitle.Text = "📦 LIST DEVELOPER PRODUCTS"
	end)
end)

-- Open Config
openConfigBtn.MouseButton1Click:Connect(function()
	local sdk = ServerScriptService:FindFirstChild("PLAY3SDK")
	if sdk then
		local config = sdk:FindFirstChild("Config")
		if config then
			Selection:Set({config})
			print("[PLAY3.AI] Config selected - check Properties panel")
		else
			warn("[PLAY3.AI] Config not found in SDK")
		end
	else
		warn("[PLAY3.AI] SDK not installed yet. Install it first from the Setup tab.")
	end
end)

-- Initial
task.spawn(function()
	task.wait(0.5)
	refreshStatus()
	checkForPluginUpdate()
end)

print("[PLAY3.AI] SDK Plugin loaded - v" .. PLUGIN_VERSION)
]]></ProtectedString>
    </Properties>
    
