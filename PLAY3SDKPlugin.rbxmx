local isValidApiKey = false
local enteredApiKey = ""
local currentTab = "setup"
local SETTINGS_KEY = "PLAY3_API_KEY"

local function saveApiKey(key)
	pcall(function() plugin:SetSetting(SETTINGS_KEY, key) end)
end

local function loadApiKey()
	local success, key = pcall(function() return plugin:GetSetting(SETTINGS_KEY) end)
	return success and key and key ~= "" and key or nil
end

