      <string name="Source"><![CDATA[--[[
	PLAY3 SDK Plugin (Lightweight Installer)

	Fetches SDK from GitHub and installs into your game.
	No embedded scripts - just a clean installer.
]]

-- Only run as a plugin
if not plugin then
	return
end

