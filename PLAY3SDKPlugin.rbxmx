local function switchTab(tab)
	currentTab = tab
	if tab == "setup" then
		setupTab.BackgroundColor3 = COLORS.neonGreen
		setupTab.TextColor3 = COLORS.voidBlack
		toolsTab.BackgroundColor3 = COLORS.voidBlack
		toolsTab.TextColor3 = COLORS.textMuted
		setupPanel.Visible = true
		toolsPanel.Visible = false
	else
		setupTab.BackgroundColor3 = COLORS.voidBlack
		setupTab.TextColor3 = COLORS.textMuted
		toolsTab.BackgroundColor3 = COLORS.neonGreen
		toolsTab.TextColor3 = COLORS.voidBlack
		setupPanel.Visible = false
		toolsPanel.Visible = true
	end
end

--============================================================
-- VERSION UTILITIES
--============================================================

local function parseVersion(v)
	local maj, min, pat = (v or "0.0.0"):match("(%d+)%.(%d+)%.(%d+)")
	return tonumber(maj) or 0, tonumber(min) or 0, tonumber(pat) or 0
end

local function isNewer(installed, remote)
	local a1, b1, c1 = parseVersion(installed)
	local a2, b2, c2 = parseVersion(remote)
	if a2 > a1 then return true end
	if a2 < a1 then return false end
	if b2 > b1 then return true end
	if b2 < b1 then return false end
	return c2 > c1
end

local function getInstalledVersion()
	local sdk = ServerScriptService:FindFirstChild("PLAY3SDK")
	if not sdk then return nil end
	local ver = sdk:FindFirstChild("_VERSION")
	if ver and ver:IsA("StringValue") then return ver.Value end
	return "0.0.0"
end

local function getInstalledApiKey()
	local sdk = ServerScriptService:FindFirstChild("PLAY3SDK")
	if not sdk then return nil end
	local config = sdk:FindFirstChild("Config")
	if config and config:IsA("ModuleScript") then
		return config.Source:match('API_KEY%s*=%s*"([^"]*)"')
	end
	return nil
end

--============================================================
-- GITHUB FETCHING
--============================================================

local function fetchFile(url)
	local success, result = pcall(function()
		return HttpService:GetAsync(url)
	end)
	if success then
		return result
	else
		warn("[PLAY3.AI] Failed to fetch:", url, result)
		return nil
	end
end

local function fetchJSON(url)
	local content = fetchFile(url)
	if content then
		local success, data = pcall(function()
			return HttpService:JSONDecode(content)
		end)
		if success then return data end
	end
	return nil
end

local function checkForUpdates()
	task.spawn(function()
		remoteVersionInfo = fetchJSON(VERSION_URL)
		if remoteVersionInfo and remoteVersionInfo.version then
			local installed = getInstalledVersion()
			if installed and isNewer(installed, remoteVersionInfo.version) then
				updateBannerText.Text = "<b>SDK v" .. remoteVersionInfo.version .. " available!</b>\n" .. (remoteVersionInfo.changelog or "")
				updateBanner.Visible = true
			end
			print("[PLAY3.AI] Latest SDK version:", remoteVersionInfo.version)
		end
	end)
end

--============================================================
-- CONFIG PRESERVATION
--============================================================

local function extractConfig(sdk)
	local config = sdk:FindFirstChild("Config")
	if config and config:IsA("ModuleScript") then
		return config.Source
	end
	return nil
end

local function mergeConfig(oldSource, newSource, newApiKey)
	local result = newSource or oldSource

	if newApiKey and newApiKey ~= "" then
		result = result:gsub('API_KEY%s*=%s*"[^"]*"', 'API_KEY = "' .. newApiKey .. '"')
	end

	if not oldSource then return result end

	-- Preserve CATALOG
	local catStart, catEnd = oldSource:find("CATALOG%s*=%s*%b{}")
	if catStart then
		local oldCatalog = oldSource:sub(catStart, catEnd)
		if oldCatalog:find("%w+%s*=%s*") then
			local newCatStart, newCatEnd = result:find("CATALOG%s*=%s*%b{}")
			if newCatStart then
				result = result:sub(1, newCatStart - 1) .. oldCatalog .. result:sub(newCatEnd + 1)
			end
		end
	end

	-- Preserve settings
	for _, setting in ipairs({"testGroupPercent", "cacheTTL", "debug"}) do
		local val = oldSource:match(setting .. "%s*=%s*([%w]+)")
		if val then
			result = result:gsub(setting .. "%s*=%s*[%w]+", setting .. " = " .. val)
		end
	end

	return result
end

--============================================================
-- API KEY VALIDATION
--============================================================

local function validateApiKey(key)
	if not key or key == "" then return false, "" end
	key = key:match("^%s*(.-)%s*$")
	return key:match(API_KEY_PATTERN) ~= nil, key
end

local function updateValidation()
	local valid, cleanKey = validateApiKey(apiKeyInput.Text)
	isValidApiKey = valid
	enteredApiKey = cleanKey
	tabBar.Visible = valid

	if apiKeyInput.Text == "" then
		validationLabel.Text = ""
		inputStroke.Color = COLORS.whiteBorder
		actionBtn.BackgroundColor3 = COLORS.whiteMuted
		actionBtn.TextColor3 = COLORS.textDim
		actionBtn.Text = "ENTER API KEY FIRST"
		actionBtn.AutoButtonColor = false
	elseif valid then
		validationLabel.Text = "Valid API key"
		validationLabel.TextColor3 = COLORS.neonGreen
		inputStroke.Color = COLORS.neonGreen
		actionBtn.AutoButtonColor = true
		saveApiKey(cleanKey)

		local installed = getInstalledVersion()
		if installed then
			actionBtn.BackgroundColor3 = COLORS.playerBlue
			actionBtn.TextColor3 = COLORS.white
			actionBtn.Text = "UPDATE SDK"
		else
			actionBtn.BackgroundColor3 = COLORS.neonGreen
			actionBtn.TextColor3 = COLORS.voidBlack
			actionBtn.Text = "INSTALL SDK"
		end
	else
		validationLabel.Text = "Invalid format"
		validationLabel.TextColor3 = COLORS.legacyRed
		inputStroke.Color = COLORS.legacyRed
		actionBtn.BackgroundColor3 = COLORS.whiteMuted
		actionBtn.TextColor3 = COLORS.textDim
		actionBtn.Text = "INVALID API KEY"
		actionBtn.AutoButtonColor = false
	end
end

--============================================================
-- INSTALLATION (FETCH FROM GITHUB)
--============================================================

local function createScript(parent, name, className, source, disabled)
	local script = Instance.new(className)
	script.Name = name
	script.Source = source
	if disabled then script.Disabled = true end
	script.Parent = parent
	return script
end

local function installSDK()
	if not isValidApiKey then
		status.Text = "Please enter a valid API key"
		status.TextColor3 = COLORS.legacyRed
		return
	end

	ChangeHistoryService:SetWaypoint("Before PLAY3 SDK Install")

	status.Text = "Fetching SDK from GitHub..."
	status.TextColor3 = COLORS.textSecondary
	actionBtn.BackgroundColor3 = COLORS.whiteMuted
	actionBtn.Text = "DOWNLOADING..."
	actionBtn.AutoButtonColor = false

	task.spawn(function()
		-- Fetch manifest
		local manifest = fetchJSON(MANIFEST_URL)
		if not manifest then
			status.Text = "Failed to fetch SDK manifest"
			status.TextColor3 = COLORS.legacyRed
			actionBtn.Text = "RETRY"
			actionBtn.AutoButtonColor = true
			return
		end

		-- Preserve existing config
		local existingSDK = ServerScriptService:FindFirstChild("PLAY3SDK")
		local existingConfig = existingSDK and extractConfig(existingSDK)

		-- Clean up old installation
		if existingSDK then existingSDK:Destroy() end

		local sps = StarterPlayer:FindFirstChild("StarterPlayerScripts")
		if sps then
			local oldClient = sps:FindFirstChild("PLAY3Client")
			if oldClient then oldClient:Destroy() end
		end

		local oldRemotes = ReplicatedStorage:FindFirstChild("PLAY3Remotes")
		if oldRemotes then oldRemotes:Destroy() end

		status.Text = "Downloading SDK files..."

		-- Create SDK folder
		local sdk = Instance.new("Folder")
		sdk.Name = "PLAY3SDK"

		-- Version tracker
		local versionVal = Instance.new("StringValue")
		versionVal.Name = "_VERSION"
		versionVal.Value = manifest.version or PLUGIN_VERSION
		versionVal.Parent = sdk

		-- Fetch and create each file from manifest
		local totalFiles = 0
		local fetchedFiles = 0

		for path, info in pairs(manifest.files or {}) do
			totalFiles = totalFiles + 1
		end

		for path, info in pairs(manifest.files or {}) do
			local url = GITHUB_BASE .. "/sdk/" .. path
			local source = fetchFile(url)

			if source then
				-- Parse path to create folder structure
				local parts = string.split(path, "/")
				local parent = sdk

				for i = 1, #parts - 1 do
					local folderName = parts[i]
					local existing = parent:FindFirstChild(folderName)
					if not existing then
						existing = Instance.new("Folder")
						existing.Name = folderName
						existing.Parent = parent
					end
					parent = existing
				end

				local fileName = parts[#parts]:gsub("%.lua$", "")
				local className = info.type or "ModuleScript"
				local disabled = info.disabled or false

				-- Special handling for Config - merge with existing
				if fileName == "Config" and existingConfig then
					source = mergeConfig(existingConfig, source, enteredApiKey)
				elseif fileName == "Config" then
					source = source:gsub('API_KEY%s*=%s*"[^"]*"', 'API_KEY = "' .. enteredApiKey .. '"')
				end

				createScript(parent, fileName, className, source, disabled)
				fetchedFiles = fetchedFiles + 1
				status.Text = string.format("Downloaded %d/%d files...", fetchedFiles, totalFiles)
			end
		end

		sdk.Parent = ServerScriptService

		-- Create client folder
		if manifest.client then
			if not sps then
				sps = StarterPlayer:WaitForChild("StarterPlayerScripts", 5)
			end
			if sps then
				local clientFolder = Instance.new("Folder")
				clientFolder.Name = "PLAY3Client"

				for path, info in pairs(manifest.client) do
					local url = GITHUB_BASE .. "/sdk/client/" .. path
					local source = fetchFile(url)
					if source then
						local fileName = path:gsub("%.lua$", "")
						createScript(clientFolder, fileName, "LocalScript", source, info.disabled or false)
					end
				end

				clientFolder.Parent = sps
			end
		end

		-- Create remotes folder
		local remotes = Instance.new("Folder")
		remotes.Name = "PLAY3Remotes"

		local showOffer = Instance.new("RemoteEvent")
		showOffer.Name = "ShowOffer"
		showOffer.Parent = remotes

		local offerResult = Instance.new("RemoteEvent")
		offerResult.Name = "OfferResult"
		offerResult.Parent = remotes

		local deviceInfo = Instance.new("RemoteEvent")
		deviceInfo.Name = "DeviceInfo"
		deviceInfo.Parent = remotes

		remotes.Parent = ReplicatedStorage

		-- Enable all scripts
		for _, desc in sdk:GetDescendants() do
			if desc:IsA("Script") or desc:IsA("LocalScript") then
				desc.Disabled = false
			end
		end

		ChangeHistoryService:SetWaypoint("After PLAY3 SDK Install")

		status.Text = "SDK installed successfully!"
		status.TextColor3 = COLORS.neonGreen
		updateBanner.Visible = false

		local config = sdk:FindFirstChild("Config")
		if config then Selection:Set({config}) end

		task.delay(2, function()
			refreshStatus()
		end)
	end)
end

--============================================================
-- STATUS REFRESH
--============================================================

function refreshStatus()
	local installed = getInstalledVersion()
	local installedKey = getInstalledApiKey()
	local savedKey = loadApiKey()

	if apiKeyInput.Text == "" then
		apiKeyInput.Text = installedKey or savedKey or ""
	end

	if installed then
		versionLabel.Text = "Installed: v" .. installed
		status.Text = "SDK is installed"
		status.TextColor3 = COLORS.neonGreen
	else
		versionLabel.Text = "v" .. PLUGIN_VERSION
		status.Text = "Enter your API key to get started"
		status.TextColor3 = COLORS.textSecondary
	end

	updateValidation()
end

--============================================================
-- VERIFICATION FUNCTIONS
--============================================================

local REQUIRED_SDK_SCRIPTS = {
	"Config",
	"init",
	"Core/APIClient",
	"Core/SignalBuilder",
	"Core/DecisionCache",
	"Collectors/StateCollector",
	"Collectors/SessionCollector",
	"Collectors/DeviceCollector",
	"Collectors/ProfileCollector",
	"Analytics/PLAY3_Analytics",
	"Analytics/HashLib",
}

local REQUIRED_REMOTES = {"ShowOffer", "OfferResult", "DeviceInfo"}

local function verifyConfig(sdk)
	local result = {pass = true, warnings = {}, errors = {}}

	local config = sdk:FindFirstChild("Config")
	if not config or not config:IsA("ModuleScript") then
		result.pass = false
		table.insert(result.errors, "Config module not found")
		return result
	end

	local source = config.Source

	-- Check API_KEY
	local apiKey = source:match('API_KEY%s*=%s*"([^"]*)"')
	if not apiKey or apiKey == "" then
		result.pass = false
		table.insert(result.errors, "API_KEY is empty")
	elseif not apiKey:match(API_KEY_PATTERN) then
		result.pass = false
		table.insert(result.errors, "API_KEY format invalid")
	else
		table.insert(result.warnings, "API_KEY: Valid format") -- Actually a pass, use for display
	end

	-- Check CATALOG exists and has products
	local catalogMatch = source:match("CATALOG%s*=%s*(%b{})")
	if not catalogMatch then
		result.pass = false
		table.insert(result.errors, "CATALOG not found")
		return result
	end

	-- Count products in catalog (look for promptId entries)
	local productCount = 0
	for _ in catalogMatch:gmatch("promptId%s*=") do
		productCount = productCount + 1
	end

	if productCount == 0 then
		result.pass = false
		table.insert(result.errors, "CATALOG has no products defined")
	else
		table.insert(result.warnings, string.format("CATALOG: %d products defined", productCount))
	end

	-- Check for required fields in products
	local hasName = catalogMatch:find("name%s*=") ~= nil
	local hasTiers = catalogMatch:find("tiers%s*=") ~= nil
	local hasTier = catalogMatch:find("tier%s*=") ~= nil
	local hasPrice = catalogMatch:find("price%s*=") ~= nil
	local hasProductId = catalogMatch:find("productId%s*=") ~= nil

	if productCount > 0 then
		if not hasName then
			table.insert(result.warnings, "WARN: Some products may be missing 'name' field")
		end
		if not hasTiers then
			table.insert(result.warnings, "WARN: Some products may be missing 'tiers' field")
		end
		if hasTiers and (not hasTier or not hasPrice or not hasProductId) then
			table.insert(result.warnings, "WARN: Some tiers may be missing required fields (tier/price/productId)")
		end
	end

	return result
end

local function verifySDKScripts(sdk)
	local result = {pass = true, warnings = {}, errors = {}, found = 0, total = #REQUIRED_SDK_SCRIPTS}

	for _, scriptPath in ipairs(REQUIRED_SDK_SCRIPTS) do
		local parts = string.split(scriptPath, "/")
		local current = sdk
		local found = true

		for _, part in ipairs(parts) do
			local child = current:FindFirstChild(part)
			if not child then
				found = false
				break
			end
			current = child
		end

		if found then
			result.found = result.found + 1
		else
			result.pass = false
			table.insert(result.errors, "Missing: " .. scriptPath)
		end
	end

	return result
end

local function verifyClientScripts()
	local result = {pass = true, warnings = {}, errors = {}}

	local sps = StarterPlayer:FindFirstChild("StarterPlayerScripts")
	if not sps then
		result.pass = false
		table.insert(result.errors, "StarterPlayerScripts not found")
		return result
	end

	local clientFolder = sps:FindFirstChild("PLAY3Client")
	if not clientFolder then
		result.pass = false
		table.insert(result.errors, "PLAY3Client folder not found")
		return result
	end

	local offerUI = clientFolder:FindFirstChild("OfferUI")
	if not offerUI then
		result.pass = false
		table.insert(result.errors, "OfferUI LocalScript not found")
	end

	return result
end

local function verifyRemotes()
	local result = {pass = true, warnings = {}, errors = {}, found = 0}

	local remotesFolder = ReplicatedStorage:FindFirstChild("PLAY3Remotes")
	if not remotesFolder then
		result.pass = false
		table.insert(result.errors, "PLAY3Remotes folder not found")
		return result
	end

	for _, remoteName in ipairs(REQUIRED_REMOTES) do
		local remote = remotesFolder:FindFirstChild(remoteName)
		if remote then
			result.found = result.found + 1
		else
			result.pass = false
			table.insert(result.errors, "Missing remote: " .. remoteName)
		end
	end

	return result
end

local function verifyProductIds(sdk)
	local result = {pass = true, warnings = {}, errors = {}, valid = 0, total = 0}

	local config = sdk:FindFirstChild("Config")
	if not config then
		table.insert(result.warnings, "Cannot verify products: Config not found")
		return result
	end

	local source = config.Source
	local productIds = {}

	-- Extract all productId values
	for productId in source:gmatch("productId%s*=%s*(%d+)") do
		local id = tonumber(productId)
		if id and id > 0 then
			productIds[id] = true
		end
	end

	for id, _ in pairs(productIds) do
		result.total = result.total + 1
	end

	if result.total == 0 then
		table.insert(result.warnings, "No productIds found in CATALOG")
		return result
	end

	-- Verify each product ID with MarketplaceService
	for id, _ in pairs(productIds) do
		local success, productInfo = pcall(function()
			return MarketplaceService:GetProductInfo(id, Enum.InfoType.Product)
		end)

		if success and productInfo then
			result.valid = result.valid + 1
		else
			table.insert(result.warnings, string.format("ProductId %d not found in game", id))
		end
	end

	return result
end

local function testAPIConnection(apiKey)
	local result = {pass = false, warnings = {}, errors = {}}

	if not apiKey or apiKey == "" or not apiKey:match(API_KEY_PATTERN) then
		table.insert(result.errors, "Invalid API key - cannot test connection")
		return result
	end

	local payload = {
		eventType = "sdk_verify",
		gameId = tostring(game.GameId),
		timestamp = os.date("!%Y-%m-%dT%H:%M:%S") .. ".000Z",
		data = {
			test = true,
			pluginVersion = PLUGIN_VERSION
		}
	}

	local success, response = pcall(function()
		return HttpService:RequestAsync({
			Url = "https://roblox.play3.ai/roblox-events",
			Method = "POST",
			Headers = {
				["Content-Type"] = "application/json",
				["x-api-key"] = apiKey
			},
			Body = HttpService:JSONEncode(payload)
		})
	end)

	if not success then
		table.insert(result.errors, "Connection failed: " .. tostring(response))
		return result
	end

	if response.StatusCode == 201 or response.StatusCode == 200 then
		result.pass = true
	elseif response.StatusCode == 401 or response.StatusCode == 403 then
		table.insert(result.errors, string.format("Auth failed (%d) - check API key", response.StatusCode))
	else
		table.insert(result.warnings, string.format("Unexpected response: %d", response.StatusCode))
		result.pass = true -- Still mark as pass if we got a response
	end

	return result
end

local function runFullVerification()
	local errors = 0
	local warnings = 0

	print("\n========== PLAY3 SDK VERIFICATION ==========\n")

	-- Check if SDK is installed
	local sdk = ServerScriptService:FindFirstChild("PLAY3SDK")
	if not sdk then
		print("SDK INSTALLATION")
		print("  [FAIL] PLAY3SDK folder not found in ServerScriptService")
		print("\n=========================================")
		print("RESULT: SDK not installed")
		return false
	end

	-- 1. Config Validation
	print("CONFIG")
	local configResult = verifyConfig(sdk)
	if configResult.pass then
		for _, msg in ipairs(configResult.warnings) do
			if msg:find("^WARN:") then
				print("  [WARN] " .. msg:sub(7))
				warnings = warnings + 1
			else
				print("  [PASS] " .. msg)
			end
		end
	end
	for _, err in ipairs(configResult.errors) do
		print("  [FAIL] " .. err)
		errors = errors + 1
	end

	-- 2. SDK Scripts Check
	print("\nSDK INSTALLATION")
	local scriptsResult = verifySDKScripts(sdk)
	if scriptsResult.pass then
		print(string.format("  [PASS] PLAY3SDK folder exists"))
		print(string.format("  [PASS] All %d core scripts present", scriptsResult.total))
	else
		print(string.format("  [PASS] PLAY3SDK folder exists"))
		print(string.format("  [WARN] %d/%d scripts found", scriptsResult.found, scriptsResult.total))
		for _, err in ipairs(scriptsResult.errors) do
			print("  [FAIL] " .. err)
			errors = errors + 1
		end
	end

	-- 3. Client Scripts Check
	print("\nCLIENT")
	local clientResult = verifyClientScripts()
	if clientResult.pass then
		print("  [PASS] PLAY3Client folder exists")
		print("  [PASS] OfferUI script present")
	else
		for _, err in ipairs(clientResult.errors) do
			print("  [FAIL] " .. err)
			errors = errors + 1
		end
	end

	-- 4. Remotes Check
	print("\nREMOTES")
	local remotesResult = verifyRemotes()
	if remotesResult.pass then
		print("  [PASS] PLAY3Remotes folder exists")
		print(string.format("  [PASS] All %d remotes present", #REQUIRED_REMOTES))
	else
		for _, err in ipairs(remotesResult.errors) do
			print("  [FAIL] " .. err)
			errors = errors + 1
		end
	end

	-- 5. Product IDs Check
	print("\nPRODUCTS")
	local productsResult = verifyProductIds(sdk)
	if productsResult.total > 0 then
		if productsResult.valid == productsResult.total then
			print(string.format("  [PASS] %d/%d product IDs valid", productsResult.valid, productsResult.total))
		else
			print(string.format("  [WARN] %d/%d product IDs valid", productsResult.valid, productsResult.total))
			for _, warn in ipairs(productsResult.warnings) do
				print("  [WARN] " .. warn)
				warnings = warnings + 1
			end
		end
	else
		for _, warn in ipairs(productsResult.warnings) do
			print("  [WARN] " .. warn)
			warnings = warnings + 1
		end
	end

	-- 6. API Connection Test
	print("\nAPI CONNECTION")
	local config = sdk:FindFirstChild("Config")
	local apiKey = config and config.Source:match('API_KEY%s*=%s*"([^"]*)"')
	local apiResult = testAPIConnection(apiKey)
	if apiResult.pass then
		print("  [PASS] Events endpoint reachable (201 OK)")
	else
		for _, err in ipairs(apiResult.errors) do
			print("  [FAIL] " .. err)
			errors = errors + 1
		end
		for _, warn in ipairs(apiResult.warnings) do
			print("  [WARN] " .. warn)
			warnings = warnings + 1
		end
	end

	-- Summary
	print("\n=========================================")
	if errors == 0 and warnings == 0 then
		print("RESULT: All checks passed!")
	else
		print(string.format("RESULT: %d error(s), %d warning(s)", errors, warnings))
	end
	print("")

	return errors == 0
end

--============================================================
-- EVENTS
--============================================================

installBtn.Click:Connect(function()
	widget.Enabled = not widget.Enabled
	if widget.Enabled then refreshStatus() end
end)

setupTab.MouseButton1Click:Connect(function() switchTab("setup") end)
toolsTab.MouseButton1Click:Connect(function() switchTab("tools") end)

apiKeyInput:GetPropertyChangedSignal("Text"):Connect(updateValidation)
apiKeyInput.FocusLost:Connect(updateValidation)

actionBtn.MouseButton1Click:Connect(function()
	if isValidApiKey then installSDK() end
end)

listProductsBtn.MouseButton1Click:Connect(function()
	listProductsTitle.Text = "FETCHING..."
	task.spawn(function()
		local products = {}
		local success, pages = pcall(function()
			return MarketplaceService:GetDeveloperProductsAsync()
		end)

		if not success or not pages then
			warn("[PLAY3.AI] Failed to fetch products")
			listProductsTitle.Text = "LIST DEVELOPER PRODUCTS"
			return
		end

		while true do
			for _, item in ipairs(pages:GetCurrentPage()) do
				table.insert(products, {
					id = item.ProductId,
					name = item.Name,
					price = item.PriceInRobux or 0,
				})
			end
			if pages.IsFinished then break end
			pcall(function() pages:AdvanceToNextPageAsync() end)
		end

		table.sort(products, function(a, b) return a.price < b.price end)
		print("\n========== DEVELOPER PRODUCTS ==========\n")
		for _, p in ipairs(products) do
			print(string.format("{ tier = X, price = %d, productId = %d }, -- %s", p.price, p.id, p.name))
		end
		print("\n=========================================\n")
		listProductsTitle.Text = "LIST DEVELOPER PRODUCTS"
	end)
end)

verifySetupBtn.MouseButton1Click:Connect(function()
	verifySetupTitle.Text = "VERIFYING..."
	verifySetupSubtitle.Text = "Running checks..."
	task.spawn(function()
		local success = runFullVerification()
		verifySetupTitle.Text = "VERIFY SETUP"
		if success then
			verifySetupSubtitle.Text = "All checks passed!"
		else
			verifySetupSubtitle.Text = "Issues found - check Output"
		end
		task.delay(3, function()
			verifySetupSubtitle.Text = "Check SDK installation & config"
		end)
	end)
end)

-- Initial
task.spawn(function()
	task.wait(0.5)
	refreshStatus()
	checkForUpdates()
end)

print("[PLAY3.AI] SDK Plugin loaded - v" .. PLUGIN_VERSION)
]]></string>
    </Properties>
  </Item>
</roblox>
